# Load libraries
library(GEOquery)
library(survival)
library(survminer)
library(TCGAbiolinks)
# Download neuroblastoma dataset from GEO
geo_id <- "GSE49710"  # GEO ID for neuroblastoma dataset
gse <- getGEO(geo_id, GSEMatrix = TRUE)
data <- exprs(gse[[1]])  # Extract expression data
# Access the clinical data, including survival information
clinical_data <- pData(gse[[1]])
clinical_data$survival_time <- as.numeric(clinical_data$`progression:ch1`)
clinical_data$status <- as.numeric(clinical_data$`death from disease:ch1`)
# Define the survival object
surv_object <- Surv(time = clinical_data$survival_time, event = clinical_data$status)
# Fit Kaplan-Meier survival model
fit <- survfit(surv_object ~ 1, data = clinical_data)
# Plot survival curve
ggsurvplot(fit,
data = clinical_data,
title = "Kaplan-Meier Survival Curve for Neuroblastoma",
xlab = "Time (Months)",
ylab = "Survival Probability",
risk.table = TRUE,
conf.int = TRUE,
pval = TRUE)
