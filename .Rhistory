# Load libraries
library(GEOquery)
library(survival)
library(survminer)
library(TCGAbiolinks)
# Download neuroblastoma dataset from GEO
geo_id <- "GSE49710"  # GEO ID for neuroblastoma dataset
gse <- getGEO(geo_id, GSEMatrix = TRUE)
expression_data <- exprs(gse[[1]])
clinical_data <- pData(gse[[1]])
# Based on previous inspection, use the relevant columns for survival
# Assuming "progression:ch1" contains the survival time and "death from disease:ch1" contains survival status
clinical_data$survival_time <- as.numeric(clinical_data$`progression:ch1`)
clinical_data$status <- as.numeric(clinical_data$`death from disease:ch1`)  # Assuming 1 = deceased, 0 = alive
# Step 3: Match sample IDs between expression and clinical data
# Transpose expression data if needed to match samples in rows
expression_data <- as.data.frame(t(expression_data))
View(expression_data)
clinical_data$gene_expression
View(clinical_data)
View(expression_data)
# Ensure that the sample IDs match exactly between expression and clinical data
common_samples <- intersect(rownames(expression_data), rownames(clinical_data))
expression_data <- expression_data[common_samples, ]
clinical_data <- clinical_data[common_samples, ]
View(clinical_data)
View(expression_data)
View(clinical_data)
gene <- "MYCN"
clinical_data$gene_expression <- expression_data[, gene]
clinical_data$expression_median <- apply(expression_data, 2, median, na.rm = TRUE)
# Find common sample IDs
common_samples <- intersect(colnames(expression_data), rownames(clinical_data))
# Subset both datasets to these common sample IDs
expression_data <- expression_data[, common_samples]
clinical_data <- clinical_data[common_samples, ]
# Now calculate the median expression across all genes (rows) for each sample
clinical_data$expression_median <- apply(expression_data, 2, median, na.rm = TRUE)
# Verify if the sizes match now
cat("Number of samples in expression_data:", ncol(expression_data), "\n")
cat("Number of samples in clinical_data:", nrow(clinical_data), "\n")
library(GEOquery)
library(survival)
library(survminer)
library(TCGAbiolinks)
# Step 1: Download neuroblastoma dataset from GEO
geo_id <- "GSE49710"  # GEO ID for neuroblastoma dataset
gse <- getGEO(geo_id, GSEMatrix = TRUE)
expression_data <- exprs(gse[[1]])
clinical_data <- pData(gse[[1]])
# Step 2: Prepare clinical data by extracting relevant survival information
# Assuming "progression:ch1" contains the survival time and "death from disease:ch1" contains survival status
clinical_data$survival_time <- as.numeric(clinical_data$`progression:ch1`)
clinical_data$status <- as.numeric(clinical_data$`death from disease:ch1`)  # Assuming 1 = deceased, 0 = alive
# Step 3: Match sample IDs between expression and clinical data
# Transpose expression data to have samples as rows and genes as columns if necessary
expression_data <- as.data.frame(t(expression_data))
# Find common sample IDs between the expression data (columns after transpose) and clinical data (row names)
common_samples <- intersect(rownames(expression_data), rownames(clinical_data))
# Subset both datasets to only include the common samples
expression_data <- expression_data[common_samples, ]
clinical_data <- clinical_data[common_samples, ]
# Step 4: Calculate median expression across all genes for each sample
# This will serve as a proxy for overall expression level if no specific gene is targeted
clinical_data$expression_median <- apply(expression_data, 1, median, na.rm = TRUE)
# Verify that the sizes match between expression_data and clinical_data
cat("Number of samples in expression_data:", nrow(expression_data), "\n")
cat("Number of samples in clinical_data:", nrow(clinical_data), "\n")
# Step 5: Define high and low expression groups based on the median expression
clinical_data$expression_group <- ifelse(clinical_data$expression_median > median(clinical_data$expression_median, na.rm = TRUE),
"High Expression", "Low Expression")
# Step 6: Prepare survival object for analysis
surv_object <- Surv(time = clinical_data$survival_time, event = clinical_data$status)
# Step 7: Perform Kaplan-Meier survival analysis based on expression group
fit <- survfit(surv_object ~ expression_group, data = clinical_data)
# Step 8: Plot the Kaplan-Meier survival curve
ggsurvplot(fit,
data = clinical_data,
pval = TRUE,
conf.int = TRUE,
title = "Kaplan-Meier Survival Curve by Expression Level",
xlab = "Time (Months)",
legend.title = "Expression Group",
legend.labs = c("High Expression", "Low Expression"),
palette = c("red", "blue"))
